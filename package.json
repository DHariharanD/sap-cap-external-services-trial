{
  "name": "sap-cap-external-services-trial-cds",
  "version": "1.0.0",
  "devDependencies": {
    "@sap/cds-dk": "^9.7.2"
  },
  "cds": {
    "requires": {
      "CE_PURCHASEORDER_0001": {
        "kind": "odata-v4",
        "model": "srv/external/CE_PURCHASEORDER_0001",
